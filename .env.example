# ============================================
# AI API 服务配置文件
# ============================================
# 使用方法：
#   1. 复制此文件为 .env
#   2. 修改配置值
#   3. 运行 source .env 加载配置
#
# 注意：.env 文件包含敏感信息，请勿提交到 Git 仓库！

# ============================================
# DeepSeek API 配置
# ============================================
# 官方文档：https://api-docs.deepseek.com/

# API 基础地址
export AI_API_URL="https://api.deepseek.com/v1"

# API 密钥（请替换为你自己的密钥）
export AI_API_KEY="your-api-key-here"

# 模型名称
# DeepSeek 可用模型：
#   - deepseek-chat：通用对话模型
#   - deepseek-reasoner：推理模型
export AI_MODEL="deepseek-chat"

# ============================================
# 系统提示词（可选）
# ============================================
export AI_SYSTEM_PROMPT="你是一个友好、专业的 AI 助手。请用简洁清晰的中文回答用户的问题。"

# ============================================
# 服务器配置
# ============================================
export PORT="8080"

# ============================================
# 数据库配置
# ============================================
# SQLite 数据库文件路径
export DB_PATH="./data/ai-api.db"

# ============================================
# 安全配置
# ============================================
# JWT 签名密钥
# 警告：生产环境请使用随机生成的长字符串！
# 可以使用以下命令生成：
#   openssl rand -base64 32
export JWT_SECRET="your-super-secret-jwt-key-change-me-in-production"
